{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScriptureAtlasNode",
  "type": "object",
  "required": ["slug", "title", "figures", "themes", "alignment_rows", "similarities", "differences", "source_metadata", "commentary_notes"],
  "properties": {
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "figures": { "type": "array", "items": { "type": "string" } },
    "themes": { "type": "array", "items": { "type": "string" } },
    "alignment_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["beat"],
        "properties": {
          "beat": { "type": "string" },
          "summary": { "type": "string" },
          "difference_tags": { "type": "array", "items": { "$ref": "#/$defs/lens" } },
          "torah": { "$ref": "#/$defs/traditionEntry" },
          "christian_bible": { "$ref": "#/$defs/traditionEntry" },
          "quran": { "$ref": "#/$defs/traditionEntry" }
        },
        "additionalProperties": false
      }
    },
    "similarities": { "type": "array", "items": { "type": "string" } },
    "differences": { "type": "array", "items": { "$ref": "#/$defs/differenceNote" } },
    "source_metadata": {
      "type": "object",
      "required": ["compiled_by", "last_reviewed", "citations"],
      "properties": {
        "compiled_by": { "type": "string" },
        "last_reviewed": { "type": "string" },
        "citations": { "type": "array", "items": { "$ref": "#/$defs/sourceCitation" } }
      },
      "additionalProperties": false
    },
    "commentary_notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "lens": { "type": "string", "enum": ["textual", "theological", "historical", "political reception", "translation issue"] },
    "differenceNote": {
      "type": "object",
      "required": ["lens", "description"],
      "properties": {
        "lens": { "$ref": "#/$defs/lens" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "commentaryNote": {
      "type": "object",
      "required": ["title", "detail"],
      "properties": {
        "title": { "type": "string" },
        "detail": { "type": "string" }
      },
      "additionalProperties": false
    },
    "traditionEntry": {
      "type": "object",
      "properties": {
        "references": { "type": "array", "items": { "type": "string" } },
        "translation": { "type": "string" },
        "excerpt": { "type": "string" },
        "notes": { "type": "array", "items": { "$ref": "#/$defs/commentaryNote" } }
      },
      "additionalProperties": false
    },
    "sourceCitation": {
      "type": "object",
      "required": ["tradition", "reference", "note"],
      "properties": {
        "tradition": { "type": "string" },
        "reference": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
