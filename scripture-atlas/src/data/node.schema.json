{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScriptureAtlasNode",
  "type": "object",
  "required": [
    "slug",
    "title",
    "figures",
    "themes",
    "passages",
    "similarities",
    "differences",
    "source_metadata",
    "commentary_notes"
  ],
  "properties": {
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "figures": { "type": "array", "items": { "type": "string" } },
    "themes": { "type": "array", "items": { "type": "string" } },
    "passages": {
      "type": "object",
      "required": ["torah", "christian_bible", "quran"],
      "properties": {
        "torah": { "type": "array", "items": { "type": "string" } },
        "christian_bible": { "type": "array", "items": { "type": "string" } },
        "quran": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "similarities": { "type": "array", "items": { "type": "string" } },
    "differences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lens", "description"],
        "properties": {
          "lens": {
            "type": "string",
            "enum": ["textual", "theological", "historical", "political reception", "translation issue"]
          },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "source_metadata": {
      "type": "object",
      "required": ["compiled_by", "last_reviewed", "citations"],
      "properties": {
        "compiled_by": { "type": "string" },
        "last_reviewed": { "type": "string" },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tradition", "reference", "note"],
            "properties": {
              "tradition": { "type": "string" },
              "reference": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "commentary_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
